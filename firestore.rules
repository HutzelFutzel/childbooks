rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedInAs(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    // Shape guard for the profile root doc. Validates known fields' types and
    // caps the field count so the doc can grow over time without being abused.
    // Unknown keys (e.g. future additions) are tolerated under the count cap.
    function isValidProfile(d) {
      return d.keys().size() <= 40
        && (!('schemaVersion' in d) || d.schemaVersion is int)
        && (!('displayName' in d) || d.displayName == null || (d.displayName is string && d.displayName.size() <= 200))
        && (!('email' in d) || d.email == null || (d.email is string && d.email.size() <= 320))
        && (!('photoURL' in d) || d.photoURL == null || (d.photoURL is string && d.photoURL.size() <= 2000))
        && (!('defaultAddressId' in d) || d.defaultAddressId == null || (d.defaultAddressId is string && d.defaultAddressId.size() <= 200))
        && (!('locale' in d) || d.locale == null || (d.locale is string && d.locale.size() <= 35))
        && (!('currency' in d) || d.currency == null || (d.currency is string && d.currency.size() <= 3))
        && (!('marketingOptIn' in d) || d.marketingOptIn is bool);
    }

    // Shape guard for a saved address. Required fields must be present strings
    // within sane bounds; optional fields are type-checked only when present.
    function isValidAddress(d) {
      return d.keys().size() <= 20
        && d.recipientName is string && d.recipientName.size() <= 200
        && d.line1 is string && d.line1.size() <= 300
        && d.city is string && d.city.size() <= 200
        && d.postal is string && d.postal.size() <= 40
        && d.country is string && d.country.size() <= 2
        && (!('label' in d) || (d.label is string && d.label.size() <= 120))
        && (!('phone' in d) || (d.phone is string && d.phone.size() <= 60))
        && (!('email' in d) || (d.email is string && d.email.size() <= 320))
        && (!('line2' in d) || (d.line2 is string && d.line2.size() <= 300))
        && (!('region' in d) || (d.region is string && d.region.size() <= 200));
    }

    // Per-user private space: a signed-in user may READ all of their own docs
    // under users/{uid}/**. The backend (Admin SDK) bypasses these rules.
    match /users/{uid}/{document=**} {
      allow read: if signedInAs(uid);
    }
    // Client WRITES are limited to the app's own data (project/settings KV and
    // generation jobs). Usage/cost records (users/{uid}/usage,
    // users/{uid}/usageAggregates) and the Spark ledger (users/{uid}/sparksLedger)
    // are written only by the backend, so they stay read-only to the client and
    // can't be forged or deleted (they fall through to the default-deny write).
    match /users/{uid}/store/{document=**} {
      allow write: if signedInAs(uid);
    }
    // The client only CREATES the job document (its task specs live on that doc);
    // the backend expands it into the `tasks` subcollection and writes every
    // render result there. Scoping the write to the job doc itself (not
    // `{document=**}`) keeps the task subcollection backend-only, so a client
    // can't forge a completed task/result.
    match /users/{uid}/jobs/{jobId} {
      allow write: if signedInAs(uid);
    }
    // Per-task docs are read by the owner (also via the project-scoped
    // collection-group query, which needs a rule that authorizes by the doc's
    // own `uid` field — the path wildcard can't be correlated to a field filter
    // for group queries). Writes fall through to default-deny (backend only).
    match /{path=**}/tasks/{taskId} {
      allow read: if request.auth != null && resource.data.uid == request.auth.uid;
    }

    // The Spark balance is backend-authoritative (written only via the Admin SDK
    // after a transactional ledger entry). A client may carry it through an
    // unrelated profile write, but must never CHANGE it — otherwise anyone could
    // mint themselves Sparks by patching their own profile doc.
    function sparkBalanceUnchanged() {
      return !('sparkBalance' in request.resource.data)
        || (resource != null && 'sparkBalance' in resource.data
            && request.resource.data.sparkBalance == resource.data.sparkBalance);
    }

    // Referral attribution + reward state are backend-authoritative too (set
    // via /account/referral routes and the Stripe webhook). A client patching
    // its own profile must never introduce or alter them.
    function referralFieldsUnchanged() {
      return fieldUnchanged('referralCode')
        && fieldUnchanged('referredBy')
        && fieldUnchanged('referredAt')
        && fieldUnchanged('referralRewardedAt');
    }

    function fieldUnchanged(f) {
      return !(f in request.resource.data)
        || (resource != null && f in resource.data
            && request.resource.data[f] == resource.data[f]);
    }

    // Profile root doc + saved address book. Owner-only, with field validation
    // on writes. The broad `users/{uid}/**` read rule above does NOT cover the
    // `users/{uid}` doc itself (the recursive wildcard needs >=1 extra segment),
    // so the profile doc gets its own read rule. Orders keep their own
    // authoritative copy of the shipping address — these just prefill checkout.
    match /users/{uid} {
      allow read: if signedInAs(uid);
      allow write: if signedInAs(uid) && isValidProfile(request.resource.data)
        && sparkBalanceUnchanged() && referralFieldsUnchanged();
    }
    match /users/{uid}/addresses/{addressId} {
      allow create, update: if signedInAs(uid) && isValidAddress(request.resource.data);
      allow delete: if signedInAs(uid);
    }

    // Admin membership: the source of truth for admin status, set in the
    // Firebase console. A user may read their own doc (to drive the cosmetic UI
    // gate); writes are denied to all clients (set in the console / Admin SDK).
    match /admins/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    function isAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Global, admin-managed configuration (model config, art-style examples…).
    // World-readable so the wizard + client can resolve them; writes only ever
    // happen through the backend (Admin SDK) after `requireAdmin`.
    // Exception: the raw provider rate table (`modelCosts`) is admin-only —
    // the storefront reads the derived `modelCostsPublic` projection instead
    // (flat per-image estimates, written by the backend on every save).
    match /appConfig/{doc} {
      allow read: if doc != 'modelCosts' || isAdmin();
      allow write: if false;
    }

    // Blog / articles. Full post bodies live in their own collection (they'd
    // outgrow a single appConfig doc). Published posts are world-readable so the
    // App Router can render article pages; drafts stay hidden. Writes only ever
    // happen through the admin-gated backend (Admin SDK). The lightweight index
    // projection is `appConfig/blogIndex`, already covered by the rule above.
    match /blog/{slug} {
      allow read: if resource.data.status == 'published';
      allow write: if false;
    }

    // Blog analytics aggregates (cookieless, first-party). Written only by the
    // backend (Admin SDK) from the tokenless `/blog-track` beacon; read only by
    // the admin dashboard via the admin-gated backend. Never client-accessible
    // — the per-day `days/{date}` dedupe docs hold rotating visitor hashes and
    // must not be exposed. The top-level deny-all already covers this, but we
    // spell it out for clarity.
    match /blogStats/{slug} {
      allow read, write: if false;
      match /days/{date} {
        allow read, write: if false;
      }
    }

    // Admin dashboard settings (exclusion lists, timezone, refresh interval).
    // Holds the email/domain exclusion list, so — unlike `appConfig/*` — it must
    // NEVER be world-readable. Read/written only via the admin-gated backend.
    match /adminSettings/{doc} {
      allow read, write: if false;
    }

    // Append-only authentication event log, written by the Auth blocking
    // functions (Admin SDK). Read only via the admin-gated analytics routes.
    match /analyticsEvents/{doc} {
      allow read, write: if false;
    }

    // Everything else is denied to direct client access.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
