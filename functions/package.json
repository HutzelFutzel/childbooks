{
  "name": "functions",
  "private": true,
  "version": "0.1.0",
  "description": "Childbooks Firebase Functions backend (secret holder + AI proxy + Lulu fulfillment).",
  "main": "lib/index.js",
  "engines": {
    "node": "20"
  },
  "scripts": {
    "build": "node esbuild.mjs",
    "build:watch": "node esbuild.mjs --watch",
    "typecheck": "tsc --noEmit",
    "dev": "node esbuild.mjs --watch",
    "serve": "yarn build && firebase emulators:start --only functions"
  },
  "dependencies": {
    "express": "^4.21.2",
    "firebase-admin": "^13.0.2",
    "firebase-functions": "^6.3.2",
    "sharp": "^0.35.2",
    "stripe": "^22.3.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "concurrently": "^9.1.0",
    "esbuild": "^0.25.0",
    "typescript": "^5.8.3"
  },
  "optionalDependencies": {
    "@img/sharp-linux-x64": "0.35.2",
    "@img/sharp-libvips-linux-x64": "1.3.1"
  }
}
