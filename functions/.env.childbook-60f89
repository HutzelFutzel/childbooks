# ──────────────────────────────────────────────────────────────────────────
# Childbooks backend — PRODUCTION non-secret runtime config (project childbook-60f89)
#
# Firebase loads this file automatically when you `firebase deploy` against the
# `childbook-60f89` project, injecting these into the function's process.env
# where `loadServerConfig(process.env)` reads them. It is committed ON PURPOSE.
#
# ⚠️  NON-SECRET VALUES ONLY. Never put API keys / client secrets / webhook
#     signing secrets here — those live in Cloud Secret Manager:
#         firebase functions:secrets:set OPENAI_API_KEY      (etc.)
#
# NOTE: the emualator also reads this file, but `.env.local` (git-ignored) takes
# precedence locally — so local dev keeps its own LULU_ENV/STRIPE_ENV/PUBLIC_APP_URL.
# ──────────────────────────────────────────────────────────────────────────

# Public storefront origin — used for Stripe Checkout success/cancel + Customer
# Portal return redirects. MUST be your real, https App Hosting domain or those
# redirects break. Defaults to http://localhost:3000 when unset.
# TODO: replace with your actual App Hosting domain (Firebase console → App Hosting).
PUBLIC_APP_URL=https://childbooks.studio

# Sandbox vs live for fulfillment + payments. Kept on "sandbox" so deploying
# doesn't flip real customers into a half-configured live mode by accident.
#
# To GO LIVE (do these first, then flip both to "live" and redeploy functions):
#   1. firebase functions:secrets:set LULU_LIVE_CLIENT_KEY / LULU_LIVE_CLIENT_SECRET
#   2. firebase functions:secrets:set STRIPE_LIVE_SECRET_KEY
#   3. Register the live Stripe webhook (…/api/stripe-webhook), then
#      firebase functions:secrets:set STRIPE_LIVE_WEBHOOK_SECRET
#   4. Register the live Lulu status webhook via POST /admin/print/webhooks
#   5. Verify everything in Admin → Configuration → System health
LULU_ENV=sandbox
STRIPE_ENV=sandbox

# Bind the LIVE secrets to the function. Keep "false" until you've actually
# created the live keys (firebase functions:secrets:set STRIPE_LIVE_SECRET_KEY,
# LULU_LIVE_CLIENT_KEY, …) — otherwise deploy fails demanding secrets you don't
# have yet. Set to "true" + redeploy to enable live mode and the admin
# sandbox↔live toggle. While "false", a sandbox-only deploy needs NO live keys.
LIVE_ENABLED=false

# Storage bucket the backend reads/writes. Must match the client's
# NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET (apphosting.yaml).
STORAGE_BUCKET=childbook-60f89.firebasestorage.app
