# ──────────────────────────────────────────────────────────────────────────
# Childbooks backend (Firebase Functions) — environment template
#
# These are the secrets/config the BACKEND owns. In production they live in
# Cloud Secret Manager (see functions:secrets:set) and are injected into the
# runtime automatically. For LOCAL emulator development, copy this file to
# `.env.local` (git-ignored) and fill in real values — the emulator loads it
# into process.env, where `loadServerConfig(process.env)` reads them.
#
#     cp functions/.env.example functions/.env.local
# ──────────────────────────────────────────────────────────────────────────

# ── AI providers ───────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-dummy-openai-key-replace-me
GOOGLE_API_KEY=AIzaSy-dummy-gemini-key-replace-me

# ── Guest (anonymous user) cleanup ─────────────────────────────────────────
# The `cleanupAnonymousUsers` scheduled function deletes anonymous accounts (and
# their Firestore/Storage data) that have been inactive for this many days.
# Defaults to 30 when unset. Lower it to drain a backlog faster, raise it to keep
# returning guests longer.
# ANON_CLEANUP_MAX_AGE_DAYS=30

# ── Cost suggestion (admin "Suggest" button) ──────────────────────────────
# Official pricing pages the admin cost-suggester reads with a cheap text model.
# Defaults below are baked in; override only if a provider moves its page (so no
# code change is needed). New models work automatically — they're matched by id
# in the live page, nothing is hardcoded per model.
# GOOGLE_PRICING_URL=https://ai.google.dev/gemini-api/docs/pricing
# OPENAI_PRICING_URL=https://developers.openai.com/api/docs/pricing

# ── Lulu (print-on-demand) ─────────────────────────────────────────────────
# Lulu issues SEPARATE OAuth credentials per environment: the sandbox pair only
# works against api.sandbox.lulu.com, the live pair only against api.lulu.com.
# Set both pairs; the one matching LULU_ENV is used.
LULU_SANDBOX_CLIENT_KEY=dummy-lulu-sandbox-client-key-replace-me
LULU_SANDBOX_CLIENT_SECRET=dummy-lulu-sandbox-client-secret-replace-me
LULU_LIVE_CLIENT_KEY=dummy-lulu-live-client-key-replace-me
LULU_LIVE_CLIENT_SECRET=dummy-lulu-live-client-secret-replace-me
# "sandbox" (test) or "live" (real orders + charges). Keep on sandbox.
LULU_ENV=sandbox

# Legacy single-pair fallback (used for whichever LULU_ENV is active if the
# env-specific vars above are unset). Prefer the *_SANDBOX_*/*_LIVE_* pairs.
# LULU_CLIENT_KEY=
# LULU_CLIENT_SECRET=

# ── Stripe (payments) ──────────────────────────────────────────────────────
# Stripe holds a SECRET API key + a webhook SIGNING secret per environment. The
# sandbox/test pair (sk_test_…, whsec_…) only works in test mode; the live pair
# (sk_live_…) takes real money. Set both; the one matching STRIPE_ENV is used.
#
# STRIPE_ENV mirrors LULU_ENV when unset, so a single switch flips the whole
# backend between sandbox and live. Keep on sandbox for development.
STRIPE_ENV=sandbox
STRIPE_SANDBOX_SECRET_KEY=sk_test_dummy-stripe-secret-replace-me
# The webhook signing secret. In LOCAL dev `yarn dev:backend --stripe` starts the
# Stripe CLI listener and injects this automatically — leave it blank locally. In
# production, set it to the signing secret of the registered webhook endpoint.
STRIPE_SANDBOX_WEBHOOK_SECRET=
STRIPE_LIVE_SECRET_KEY=sk_live_dummy-stripe-secret-replace-me
STRIPE_LIVE_WEBHOOK_SECRET=whsec_dummy-live-webhook-secret-replace-me

# Public base URL of the storefront, used for Stripe Checkout success/cancel
# redirects and the Customer Portal return URL. Defaults to http://localhost:3000
# when unset (fine for local dev).
# PUBLIC_APP_URL=https://your-app.example.com

# ── Asset hosting / generated images (Firebase Storage via Admin SDK) ──────
# The backend uploads generated images + print files as admin using Application
# Default Credentials (NO private key file needed). This MUST match the client's
# NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET exactly — otherwise images are written to a
# bucket the browser can't read and show up empty. Defaults to
# "<projectId>.firebasestorage.app" when unset.
# NOTE: the FIREBASE_ prefix is reserved by Firebase and can't be set in a
# functions .env file, so the override uses the unprefixed STORAGE_BUCKET.
# STORAGE_BUCKET=your-project-id.firebasestorage.app

# ── Local end-to-end print orders (optional) ───────────────────────────────
# Placing a print order hands the provider (Lulu) Firebase download URLs to the
# interior/cover files; the provider then DOWNLOADS them. Under the Storage
# emulator those URLs are http://127.0.0.1:9199/... which the provider can't
# reach, so a sandbox order's file validation fails.
#
# `yarn dev:backend --order` (or `yarn dev:all --order`) opens an ngrok tunnel to
# the Storage emulator and exports STORAGE_PUBLIC_BASE_URL automatically, so the
# full flow works locally. It only needs a FREE ngrok authtoken:
#   https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=your-ngrok-authtoken-replace-me
# Optional: pin a reserved ngrok domain so the URL is stable across runs.
# NGROK_DOMAIN=your-subdomain.ngrok-free.app
#
# Everyday dev (without --order) needs none of this; quoting and cover-dimensions
# never call back into your machine. You normally won't set STORAGE_PUBLIC_BASE_URL
# by hand — the --order flag does it — but you can override it if needed:
# STORAGE_PUBLIC_BASE_URL=https://<your-subdomain>.ngrok.app

# ── Order status webhooks (provider → backend) ─────────────────────────────
# The provider (Lulu) POSTs order-status updates to our `/print-webhook` receiver,
# which verifies the `Lulu-HMAC-SHA256` signature using the SAME client secret
# above — no extra secret to configure.
#
#   - Local dev: `yarn dev:backend --order` (or `--all --order`) opens a SECOND
#     ngrok tunnel to the Functions emulator (port 5001) and AUTO-REGISTERS the
#     webhook with Lulu for the active LULU_ENV, cleaning it up on exit. Nothing
#     to do by hand. (Needs the same NGROK_AUTHTOKEN + Lulu creds above.)
#   - Production: register the deployed receiver once per environment via the
#     admin endpoint `POST /admin/print/webhooks` { "url": "https://<host>/print-webhook" }
#     (sandbox + live use separate credentials, so register under each). Manage
#     with GET/DELETE `/admin/print/webhooks` and test via `.../:id/test`.
