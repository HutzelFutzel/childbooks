# ──────────────────────────────────────────────────────────────────────────
# Childbooks — server environment template
#
# This file is the canonical list of secrets/config the BACKEND will read once
# the app is split into frontend + backend. It is committed as documentation;
# copy it to `.env` and fill in real values there (`.env` is git-ignored).
#
#     cp .env.example .env
#
# IMPORTANT: today there is no backend. This template is the canonical list the
# backend will read later via `loadServerConfig(process.env)` (see
# `books-frontend/src/core/config/serverEnv.ts`). The desktop (Tauri) app reads
# AI keys from local app settings, and reads the Lulu credentials from the
# FRONTEND env file at build time — see `books-frontend/.env.example`, whose
# vars are the same names prefixed with `VITE_` (Vite only exposes `VITE_*`).
#
# Values below are DUMMY placeholders — replace them. Never commit real keys.
# ──────────────────────────────────────────────────────────────────────────

# ── AI providers (story text + illustration generation) ────────────────────
# OpenAI API key — https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-dummy-openai-key-replace-me
# Google Gemini API key — https://aistudio.google.com/apikey
GOOGLE_API_KEY=AIzaSy-dummy-gemini-key-replace-me

# ── Lulu (print-on-demand fulfillment) ─────────────────────────────────────
# Lulu uses OAuth2 client-credentials: create a Client Key + Client Secret in
# the Lulu developer portal (sandbox: developers.sandbox.lulu.com). The app
# exchanges them for a short-lived bearer token automatically.
LULU_CLIENT_KEY=dummy-lulu-client-key-replace-me
LULU_CLIENT_SECRET=dummy-lulu-client-secret-replace-me
# Which Lulu environment to target: "sandbox" (test, never charged/produced)
# or "live" (real orders, real charges). Keep this on sandbox until launch.
LULU_ENV=sandbox

# ── Asset hosting (where print-ready PDFs are uploaded) ─────────────────────
# Lulu fetches your interior + cover files from public URLs, so they must be
# uploaded to a reachable object store / file gateway first.
#   ASSET_HOST_KIND=manual   → no host (orders fail with a clear message)
#   ASSET_HOST_KIND=httpPut  → upload via authenticated HTTP PUT (see httpPut.ts)
#   ASSET_HOST_KIND=firebase → Firebase Storage (current default; see below)
ASSET_HOST_KIND=firebase

# Firebase Storage (default). On the FRONTEND these are the same values prefixed
# with `VITE_` (see books-frontend/.env.example).
#
# Service-account (admin) credentials — preferred (uploads as admin; no open
# Storage rules needed). Private key on one line with literal "\n" escapes.
FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"
#
# Web SDK config (used only if the service-account vars are blank).
FIREBASE_API_KEY=dummy-firebase-api-key-replace-me
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
FIREBASE_APP_ID=1:000000000000:web:replace-me
FIREBASE_MESSAGING_SENDER_ID=000000000000

# httpPut alternative (only used when ASSET_HOST_KIND=httpPut).
# Base URL files are PUT to (object store / gateway accepting authenticated PUT).
ASSET_UPLOAD_BASE_URL=https://uploads.example.com/childbooks
# Public base URL the same files are served from (often equals the upload URL).
ASSET_PUBLIC_BASE_URL=https://cdn.example.com/childbooks
# Optional Authorization header sent with each upload (e.g. a pre-shared token).
ASSET_AUTH_HEADER=Bearer dummy-asset-host-token-replace-me
