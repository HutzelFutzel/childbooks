# ──────────────────────────────────────────────────────────────────────────
# Childbooks — frontend (Tauri desktop) environment template
#
# Vite only exposes variables prefixed with `VITE_` to client code, and inlines
# them at BUILD time. Copy this file to `.env` and fill in real values:
#
#     cp .env.example .env
#
# `.env` is git-ignored. Never commit real keys.
# ──────────────────────────────────────────────────────────────────────────

# ── Lulu (print-on-demand fulfillment) ─────────────────────────────────────
# OAuth2 client-credentials from the Lulu developer portal. Sandbox and live are
# SEPARATE accounts with their own key/secret — fill in whichever you have.
#   Sandbox portal: https://developers.sandbox.lulu.com
#   Live portal:    https://developers.lulu.com
# The app exchanges these for a bearer token automatically (no manual step).
#
# Which Lulu environment to target: "sandbox" (test orders, never produced or
# charged) or "live" (real orders + charges). This toggle selects the matching
# credential pair below. Keep on sandbox until launch.
VITE_LULU_ENV=sandbox

# Sandbox credentials (used when VITE_LULU_ENV=sandbox).
VITE_LULU_SANDBOX_CLIENT_KEY=dummy-lulu-sandbox-client-key-replace-me
VITE_LULU_SANDBOX_CLIENT_SECRET=dummy-lulu-sandbox-client-secret-replace-me

# Live credentials (used when VITE_LULU_ENV=live).
# WARNING: in this no-backend desktop build these are inlined into the bundle —
# do not distribute a build containing real live keys; move them to the backend.
VITE_LULU_LIVE_CLIENT_KEY=dummy-lulu-live-client-key-replace-me
VITE_LULU_LIVE_CLIENT_SECRET=dummy-lulu-live-client-secret-replace-me

# ── Firebase Storage (asset hosting for print-ready PDFs) ───────────────────
# Lulu downloads your interior + cover PDFs from public URLs; we upload them to
# Firebase Storage and hand Lulu the download URL. Two ways to authenticate:
#
# (A) SERVICE ACCOUNT (admin) — RECOMMENDED FOR PRIVATE DEV. Uploads as admin so
#     you do NOT need to open Storage rules or configure CORS. From the
#     service-account JSON (Firebase console → Project settings → Service
#     accounts → Generate new private key) copy `client_email` and `private_key`.
#     Put the private key on ONE line with literal "\n" escapes, double-quoted.
#     ⚠️ The key is inlined into the app bundle — PRIVATE BUILDS ONLY; move it to
#     a backend (Admin SDK) before distributing.
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
VITE_FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxx@your-project-id.iam.gserviceaccount.com
VITE_FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"

# (B) WEB SDK config — alternative; used only if the two SA vars above are blank.
#     These are the public web config (Project settings → Your apps → Web app →
#     Config). Requires open Storage rules + bucket CORS (see notes).
VITE_FIREBASE_API_KEY=dummy-firebase-api-key-replace-me
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_APP_ID=1:000000000000:web:replace-me
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
