# ──────────────────────────────────────────────────────────────────────────
# Childbooks — frontend (Next.js) environment template
#
# Next.js exposes ONLY variables prefixed with `NEXT_PUBLIC_` to the browser.
# None of these are secret: the real provider/Lulu keys live on the BACKEND
# (see functions/.env.example).
#
# Which file loads when (highest priority first):
#   process.env  >  .env.${NODE_ENV}.local  >  .env.local  >
#   .env.${NODE_ENV}  >  .env
# `next dev` runs as development; `next build`/`next start` run as production,
# so the right file is picked automatically — you don't toggle values by hand.
#
# Recommended setup:
#   - .env             shared, non-secret public config (this template's keys)
#   - .env.development  (optional) dev-only overrides; defaults already use the
#                       local emulators, so usually empty
#   - .env.production   (optional) for LOCAL prod builds: real backend URL +
#                       NEXT_PUBLIC_USE_FIREBASE_EMULATORS=false
#   - .env.local        personal machine overrides (git-ignored)
#
# DEPLOYED production (Firebase App Hosting) does NOT read these files — it
# builds from the repo, so production's public config lives in `apphosting.yaml`.
#
# Copy this to `.env` (or `.env.local`) and fill in values:
#     cp books-frontend/.env.example books-frontend/.env
# ──────────────────────────────────────────────────────────────────────────

# Base URL of the backend `api` Cloud Function. Leave BLANK in dev to use the
# local Functions emulator; in prod set the deployed URL (here or apphosting.yaml):
#   https://us-central1-<project-id>.cloudfunctions.net/api
NEXT_PUBLIC_BACKEND_URL=

# Public Firebase web config (safe to expose). From Firebase Console →
# Project settings → Your apps → Web app. In dev (emulators) these can be blank.
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
# Optional: Google Analytics for Firebase (the "G-XXXXXXXXXX" measurement id).
# Leave blank to disable analytics. Ignored in dev / against the emulators.
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Force the Firebase client SDK to the local emulators ("true") or the real
# project ("false"). Leave BLANK to auto-detect: emulators in dev, real in prod.
NEXT_PUBLIC_USE_FIREBASE_EMULATORS=
